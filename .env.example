# Supabase — public (anon) credentials, safe for the client; protected by RLS.
# Without these, the booking form still submits a graceful success message.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by the /admin bookings view. NEVER prefix these PUBLIC_
# and never expose them client-side. The service key bypasses RLS.
SUPABASE_SERVICE_KEY=
ADMIN_USER=
ADMIN_PASSWORD=
