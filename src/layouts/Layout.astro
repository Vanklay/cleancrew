---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { LANGUAGES, type Lang } from '../i18n/config';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path?: string;
  type?: 'website' | 'article';
  faq?: { q: string; a: string }[];
  service?: { name: string; serviceType: string; description: string };
}
const { lang, title, description, path, type, faq, service } = Astro.props;
---
<!doctype html>
<html lang={LANGUAGES[lang].locale} dir={LANGUAGES[lang].dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>document.documentElement.classList.add('js')</script>
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,900&display=swap" />
    <Seo lang={lang} title={title} description={description} path={path} type={type} faq={faq} service={service} />
  </head>
  <body>
    <Nav />
    <main><slot /></main>
    <Footer />
    <script>
      // Seamless scroll reveal — observe once, then disconnect. Tiny + fast.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
          }
        },
        { rootMargin: '0px 0px -8% 0px' },
      );
      for (const el of document.querySelectorAll('.reveal')) io.observe(el);
    </script>
  </body>
</html>
