---
import { LANGUAGES, LANG_KEYS, SITE, type Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path?: string;        // path WITHOUT lang prefix, e.g. 'services'
  type?: 'website' | 'article';
  faq?: { q: string; a: string }[];
  service?: { name: string; serviceType: string; description: string };
  howto?: { name: string; steps: string[] };
}
const { lang, title, description, path = '', type = 'website', faq, service, howto } = Astro.props;

const clean = path.replace(/^\/+|\/+$/g, '');
const sub = clean ? '/' + clean : '';
const canonical = `${SITE.domain}/${lang}${sub}`;
const og = LANGUAGES[lang].locale.replace('-', '_');
const ogImage = `${SITE.domain}/og/${lang}.png`;

// hreflang alternates for every locale + x-default
const alternates = LANG_KEYS.map((l) => ({ l, href: `${SITE.domain}/${l}${sub}` }));

// LocalBusiness schema — the spine of GEO/local SEO
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'CleaningBusiness',
  '@id': `${SITE.domain}/#business`,
  name: SITE.name,
  url: SITE.domain,
  email: SITE.email,
  telephone: SITE.phone,
  description,
  areaServed: { '@type': 'Country', name: 'Luxembourg' },
  address: { '@type': 'PostalAddress', addressLocality: SITE.city, addressCountry: SITE.country },
  geo: { '@type': 'GeoCoordinates', latitude: SITE.geo.lat, longitude: SITE.geo.lng },
  knowsLanguage: ['fr', 'de', 'en', 'lb', 'pt', 'es'],
  makesOffer: [
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Garage clearance', serviceType: 'Garage clearance and removal' } },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Window cleaning', serviceType: 'Residential and commercial window cleaning' } },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Driveway & surface cleaning', serviceType: 'Pressure washing of driveways, terraces and paved areas' } },
  ],
};

const faqSchema = faq && faq.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question', name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

// Per-service schema — provider links back to the LocalBusiness node by @id.
const serviceSchema = service ? {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.name,
  serviceType: service.serviceType,
  description: service.description,
  provider: { '@type': 'CleaningBusiness', '@id': `${SITE.domain}/#business` },
  areaServed: { '@type': 'Country', name: 'Luxembourg' },
  url: canonical,
} : null;

// HowTo — the service "how it works" steps (good for AEO/LLM answers).
const howToSchema = howto && howto.steps.length ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: howto.name,
  step: howto.steps.map((s, i) => ({ '@type': 'HowToStep', position: i + 1, text: s })),
} : null;

// BreadcrumbList for non-home pages. Names are localized; first segment maps to
// a nav label, a service sub-page to its service title, and any leaf (e.g. a
// blog post) falls back to the page title with the " · CleanCrew" suffix stripped.
const t = useTranslations(lang);
const segments = clean ? clean.split('/') : [];
const crumbName = (seg: string, idx: number) =>
  idx === 0 ? t(`nav.${seg}`)
  : segments[0] === 'services' ? t(`services.${seg}.title`)
  : title.replace(/\s·\s.*$/, '');
let acc = '';
const breadcrumbs = segments.length ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: SITE.name, item: `${SITE.domain}/${lang}` },
    ...segments.map((seg, i) => {
      acc += '/' + seg;
      return { '@type': 'ListItem', position: i + 2, name: crumbName(seg, i), item: `${SITE.domain}/${lang}${acc}` };
    }),
  ],
} : null;
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index,follow,max-image-preview:large" />

{alternates.map((a) => (
  <link rel="alternate" hreflang={LANGUAGES[a.l].locale} href={a.href} />
))}
<link rel="alternate" hreflang="x-default" href={`${SITE.domain}/fr${sub}`} />

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={og} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
{serviceSchema && <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />}
{howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
{breadcrumbs && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />}
