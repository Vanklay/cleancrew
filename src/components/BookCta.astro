---
// Closing CTA with the live booking wizard — grey band into the dark footer.
import BookingForm from './BookingForm.astro';
import { type Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="bg-haze py-24 md:py-32">
  <div class="container-x">
    <div class="mx-auto max-w-xl text-center">
      <p class="eyebrow reveal">{t('hero.kicker')}</p>
      <h2 class="headline reveal mt-6 text-4xl md:text-6xl" style="--d:.04s">{t('book.title')}</h2>
      <p class="reveal mt-5 text-lg leading-relaxed text-ink-soft" style="--d:.08s">{t('book.sub')}</p>
    </div>
    <div class="reveal mt-12 md:mt-14" style="--d:.12s"><BookingForm lang={lang} /></div>
  </div>
</section>
