---
// Renders the real brand files from /public so any logo/favicon update flows
// through automatically. `full` = the CleanCrew wordmark, `mark` = the bubble badge.
interface Props {
  variant?: 'full' | 'mark';
  class?: string;
}
const { variant = 'full', class: cls = '' } = Astro.props;
const src = variant === 'mark' ? '/favicon.svg' : '/logo.svg';
const dims = variant === 'mark' ? { w: 32, h: 32 } : { w: 407, h: 164 };
---
<img src={src} alt="CleanCrew" class={cls} width={dims.w} height={dims.h} decoding="async" />
