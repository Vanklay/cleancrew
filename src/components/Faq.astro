---
interface Props {
  title: string;
  items: { q: string; a: string }[];
}
const { title, items } = Astro.props;
---
<section class="section">
  <div class="container-x max-w-3xl">
    <h2 class="headline text-3xl md:text-4xl font-semibold mb-10">{title}</h2>
    <dl class="divide-y divide-line">
      {items.map((f) => (
        <div class="py-6">
          <dt class="font-semibold text-lg mb-2">{f.q}</dt>
          <dd class="text-ink-soft leading-relaxed">{f.a}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
