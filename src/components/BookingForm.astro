---
import { SERVICES, type Lang } from '../i18n/config';
import { useTranslations, useRaw } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const r = useRaw(lang);

// Labels for the client island — built from ui.ts, never hardcoded in the script.
const labels = {
  success: t('book.success'), error: t('book.error'), thanks: t('book.thanks'),
  available: t('book.calendar.available'), none: t('book.calendar.none'),
  submit: t('book.submit'), next: t('book.next'), back: t('book.back'),
  months: r('book.calendar.months') as string[], days: r('book.calendar.days') as string[],
  steps: [t('book.service'), t('book.date'), t('book.details')],
};
const services = SERVICES.map((s) => ({ key: s, title: t(`services.${s}.title`), desc: t(`services.${s}.desc`) }));
---
<div id="booking" data-lang={lang} class="mx-auto max-w-xl">
  <script type="application/json" id="bookingLabels" set:html={JSON.stringify(labels)} />
  <div class="rounded-[1.75rem] bg-white p-6 text-ink sm:p-8" style="box-shadow: var(--shadow-soft);">

    <!-- progress — caption + slim bar -->
    <div id="stepper" class="mb-8">
      <div class="flex items-baseline justify-between">
        <span id="stepName" class="text-sm font-semibold text-ink"></span>
        <span id="stepCount" class="text-xs font-medium tabular-nums text-mist"></span>
      </div>
      <div class="mt-3 h-1 w-full overflow-hidden rounded-full bg-line">
        <div id="progress" class="h-full rounded-full bg-accent transition-all duration-500 ease-out" style="width:33%"></div>
      </div>
    </div>

    <!-- STEP 1: service -->
    <section data-step="1" class="step">
      <div class="-mx-2.5">
        {services.map((s, i) => (
          <button type="button" data-service={s.key} data-title={s.title} aria-pressed={i === 0 ? 'true' : 'false'}
            class="svc-card group flex w-full items-center gap-3.5 rounded-2xl px-2.5 py-3 text-left transition-colors hover:bg-paper aria-pressed:bg-accent-soft">
            <span class="grid h-5 w-5 shrink-0 place-items-center rounded-full border-2 border-line transition-colors group-aria-pressed:border-accent">
              <span class="h-2 w-2 rounded-full bg-accent opacity-0 transition-opacity group-aria-pressed:opacity-100"></span>
            </span>
            <span class="min-w-0">
              <span class="block font-semibold leading-tight">{s.title}</span>
              <span class="mt-0.5 block text-sm leading-snug text-ink-soft">{s.desc}</span>
            </span>
          </button>
        ))}
      </div>
    </section>

    <!-- STEP 2: date -->
    <section data-step="2" class="step hidden">
      <div id="cal">
        <div class="mb-3 flex items-center justify-between">
          <button id="prev" type="button" aria-label="–" class="grid h-9 w-9 place-items-center rounded-full text-ink-soft transition-colors hover:bg-paper hover:text-accent">←</button>
          <div id="monthLabel" class="text-sm font-semibold"></div>
          <button id="next" type="button" aria-label="+" class="grid h-9 w-9 place-items-center rounded-full text-ink-soft transition-colors hover:bg-paper hover:text-accent">→</button>
        </div>
        <div id="grid" class="grid min-h-60 grid-cols-7 gap-1 text-center text-sm"></div>
        <p id="calNote" class="mt-3 text-xs text-mist"></p>
      </div>
      <input id="f_date" type="hidden" />
    </section>

    <!-- STEP 3: details -->
    <section data-step="3" class="step hidden">
      <div id="recap" class="mb-6 flex items-center gap-2 rounded-2xl bg-paper px-4 py-3 text-sm font-semibold text-ink"></div>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block text-sm font-medium text-ink-soft">{t('book.name')}<input id="f_name" class="field" required /></label>
        <label class="block text-sm font-medium text-ink-soft">{t('book.email')}<input id="f_email" type="email" class="field" required /></label>
        <label class="block text-sm font-medium text-ink-soft">{t('book.phone')}<input id="f_phone" class="field" /></label>
        <label class="block text-sm font-medium text-ink-soft sm:col-span-2">{t('book.message')}<textarea id="f_message" rows="2" class="field"></textarea></label>
      </div>
      <p id="formMsg" class="mt-4 text-sm text-red-600" role="status" aria-live="polite"></p>
    </section>

    <!-- SUCCESS -->
    <section data-step="done" class="hidden py-10 text-center">
      <div class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-accent text-2xl text-white">✓</div>
      <h2 id="doneTitle" class="display mt-5 text-2xl"></h2>
      <p id="doneMsg" class="mx-auto mt-2 max-w-sm text-ink-soft"></p>
    </section>

    <!-- nav -->
    <div id="nav" class="mt-8 flex items-center justify-between gap-4">
      <button id="back" type="button" class="invisible text-sm font-semibold text-ink-soft transition-colors hover:text-ink">{t('book.back')}</button>
      <button id="primary" type="button" class="btn">{t('book.next')}</button>
    </div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';
  const root = document.getElementById('booking')!;
  const lang = root.dataset.lang || 'fr';
  const S = JSON.parse(document.getElementById('bookingLabels')!.textContent || '{}') as {
    success: string; error: string; thanks: string; available: string; none: string;
    submit: string; next: string; back: string; months: string[]; days: string[]; steps: string[];
  };

  const panels = Array.from(root.querySelectorAll<HTMLElement>('.step'));
  const donePanel = root.querySelector<HTMLElement>('[data-step="done"]')!;
  const stepper = document.getElementById('stepper')!;
  const progress = document.getElementById('progress')!;
  const stepName = document.getElementById('stepName')!;
  const stepCount = document.getElementById('stepCount')!;
  const nav = document.getElementById('nav')!;
  const back = document.getElementById('back') as HTMLButtonElement;
  const primary = document.getElementById('primary') as HTMLButtonElement;
  const dateInput = document.getElementById('f_date') as HTMLInputElement;
  const formMsg = document.getElementById('formMsg')!;

  const segBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('.svc-card'));
  let service = segBtns[0]?.dataset.service || 'clearance';
  let serviceTitle = segBtns[0]?.dataset.title || '';
  const TOTAL = 3;
  let step = 1;

  function animate(el: HTMLElement) { el.classList.remove('step-anim'); void el.offsetWidth; el.classList.add('step-anim'); }

  function setStep(n: number) {
    step = n;
    panels.forEach((p) => p.classList.toggle('hidden', p.dataset.step !== String(step)));
    const active = panels.find((p) => p.dataset.step === String(step));
    if (active) animate(active);
    progress.style.width = `${(step / TOTAL) * 100}%`;
    stepName.textContent = S.steps[step - 1] || '';
    stepCount.textContent = `${step} / ${TOTAL}`;
    back.classList.toggle('invisible', step === 1);
    primary.textContent = step === 3 ? S.submit : S.next;
    updatePrimary();
  }

  function updatePrimary() {
    const ok = step === 2 ? !!dateInput.value : true;
    primary.disabled = !ok;
    primary.classList.toggle('opacity-40', !ok);
    primary.classList.toggle('pointer-events-none', !ok);
  }

  segBtns.forEach((btn) => btn.addEventListener('click', () => {
    segBtns.forEach((b) => b.setAttribute('aria-pressed', 'false'));
    btn.setAttribute('aria-pressed', 'true');
    service = btn.dataset.service!;
    serviceTitle = btn.dataset.title || '';
  }));

  // calendar
  let view = new Date(); view.setDate(1);
  let availableDates = new Set<string>();
  function iso(d: Date) { return d.toISOString().slice(0, 10); }
  function fmtDate(k: string) { const [y, m, d] = k.split('-').map(Number); return `${d} ${S.months[m - 1]} ${y}`; }

  async function loadSlots() {
    if (!supabase) return;
    const { data } = await supabase.from('available_slots').select('slot_date');
    if (data) availableDates = new Set(data.map((r: any) => r.slot_date));
    renderCal();
  }

  function renderCal() {
    document.getElementById('monthLabel')!.textContent = `${S.months[view.getMonth()]} ${view.getFullYear()}`;
    document.getElementById('calNote')!.textContent = availableDates.size ? S.available : S.none;
    const grid = document.getElementById('grid')!; grid.innerHTML = '';
    S.days.forEach((d) => { const e = document.createElement('div'); e.className = 'text-mist text-[11px] font-medium py-1'; e.textContent = d; grid.appendChild(e); });
    const first = (new Date(view.getFullYear(), view.getMonth(), 1).getDay() + 6) % 7;
    for (let i = 0; i < first; i++) grid.appendChild(document.createElement('div'));
    const days = new Date(view.getFullYear(), view.getMonth() + 1, 0).getDate();
    const today = iso(new Date());
    const chosen = dateInput.value;
    for (let d = 1; d <= days; d++) {
      const date = new Date(view.getFullYear(), view.getMonth(), d); const k = iso(date);
      const has = availableDates.has(k); const past = k < today;
      const btn = document.createElement('button');
      btn.type = 'button'; btn.textContent = String(d);
      const state = past ? 'text-line cursor-not-allowed'
        : k === chosen ? 'bg-ink text-white font-semibold'
        : has ? 'bg-accent-soft text-accent font-semibold hover:bg-accent hover:text-white'
        : 'text-ink-soft hover:bg-paper';
      btn.className = `h-9 rounded-lg text-sm transition-colors ${state}`;
      if (!past) btn.onclick = () => { dateInput.value = k; renderCal(); updatePrimary(); };
      grid.appendChild(btn);
    }
  }
  document.getElementById('prev')!.onclick = () => { view.setMonth(view.getMonth() - 1); renderCal(); };
  document.getElementById('next')!.onclick = () => { view.setMonth(view.getMonth() + 1); renderCal(); };

  function fillRecap() {
    document.getElementById('recap')!.textContent = `${serviceTitle} · ${dateInput.value ? fmtDate(dateInput.value) : '—'}`;
  }

  back.onclick = () => { if (step > 1) setStep(step - 1); };
  primary.onclick = async () => {
    if (step === 1) { setStep(2); return; }
    if (step === 2) { if (!dateInput.value) return; setStep(3); fillRecap(); return; }
    await submit();
  };

  async function submit() {
    const val = (id: string) => (document.getElementById(id) as HTMLInputElement).value.trim();
    const payload = { name: val('f_name'), email: val('f_email'), phone: val('f_phone'), service, req_date: dateInput.value, message: val('f_message'), lang };
    if (!payload.name || !payload.email) { formMsg.textContent = S.error; return; }
    formMsg.textContent = '';
    primary.disabled = true; primary.classList.add('opacity-40');
    let ok = true;
    if (supabase) { const { error } = await supabase.from('bookings').insert(payload); ok = !error; }
    if (ok) { showDone(); }
    else { primary.disabled = false; primary.classList.remove('opacity-40'); formMsg.textContent = S.error; }
  }

  function showDone() {
    panels.forEach((p) => p.classList.add('hidden'));
    nav.classList.add('hidden');
    stepper.classList.add('hidden');
    donePanel.classList.remove('hidden'); animate(donePanel);
    document.getElementById('doneTitle')!.textContent = S.thanks;
    document.getElementById('doneMsg')!.textContent = S.success;
  }

  setStep(1); loadSlots(); renderCal();
</script>
