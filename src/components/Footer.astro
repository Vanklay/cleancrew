---
import { getLangFromUrl, localizedPath, SERVICES, SITE } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import Logo from './Logo.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (s: string) => localizedPath(lang, s);
const year = new Date().getFullYear();
const tel = SITE.phone.replace(/\s+/g, '');
const host = SITE.domain.replace(/^https?:\/\//, '');
---
<footer class="mt-32 bg-ink text-white">
  <div class="container-x py-16 md:py-24">
    <div class="grid gap-12 md:grid-cols-12">
      <!-- brand -->
      <div class="md:col-span-5">
        <Logo variant="full" class="h-11 w-auto brightness-0 invert" />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-white/55">{t('footer.tagline')}</p>
        <a href={p('book')} class="btn mt-7 inline-flex">{t('hero.cta')}</a>
      </div>

      <!-- nav columns -->
      <div class="grid grid-cols-2 gap-10 sm:grid-cols-3 md:col-span-7">
        <nav>
          <h3 class="footer-head">{t('footer.services')}</h3>
          <ul class="space-y-3">
            {SERVICES.map((s) => (
              <li><a href={p(`services/${s}`)} class="footer-link">{t(`services.${s}.title`)}</a></li>
            ))}
          </ul>
        </nav>

        <nav>
          <h3 class="footer-head">{t('footer.company')}</h3>
          <ul class="space-y-3">
            <li><a href={p('about')} class="footer-link">{t('nav.about')}</a></li>
            <li><a href={p('blog')} class="footer-link">{t('nav.blog')}</a></li>
            <li><a href={p('contact')} class="footer-link">{t('nav.contact')}</a></li>
          </ul>
        </nav>

        <div class="col-span-2 sm:col-span-1">
          <h3 class="footer-head">{t('nav.contact')}</h3>
          <ul class="space-y-3">
            <li><a href={`mailto:${SITE.email}`} class="footer-link">{SITE.email}</a></li>
            <li><a href={`tel:${tel}`} class="footer-link">{SITE.phone}</a></li>
            <li class="text-sm text-white/55">{SITE.city}</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- bottom bar -->
    <div class="mt-16 flex flex-col gap-3 border-t border-white/10 pt-7 text-xs text-white/40 sm:flex-row sm:items-center sm:justify-between md:mt-20">
      <span>© {year} {SITE.name}. {t('footer.rights')}</span>
      <span>{host}</span>
    </div>
  </div>
</footer>
