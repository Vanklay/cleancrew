---
import { getLangFromUrl, localizedPath, SITE } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import Logo from './Logo.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (s: string) => localizedPath(lang, s);
const year = new Date().getFullYear();
---
<footer class="border-t border-line mt-32">
  <div class="container-x py-16 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <Logo variant="full" class="h-8 w-auto text-ink" />
      <p class="mt-3 text-sm text-mist max-w-xs">{t('footer.tagline')}</p>
      <p class="mt-4 text-sm text-ink-soft">{SITE.email}</p>
    </div>
    <div>
      <div class="text-xs uppercase tracking-wider text-mist mb-3">{t('footer.services')}</div>
      <ul class="space-y-2 text-sm text-ink-soft">
        <li><a href={p('services')} class="hover:text-ink">{t('services.clearance.title')}</a></li>
        <li><a href={p('services')} class="hover:text-ink">{t('services.windows.title')}</a></li>
        <li><a href={p('services')} class="hover:text-ink">{t('services.entrances.title')}</a></li>
      </ul>
    </div>
    <div>
      <div class="text-xs uppercase tracking-wider text-mist mb-3">{t('footer.company')}</div>
      <ul class="space-y-2 text-sm text-ink-soft">
        <li><a href={p('about')} class="hover:text-ink">{t('nav.about')}</a></li>
        <li><a href={p('blog')} class="hover:text-ink">{t('nav.blog')}</a></li>
        <li><a href={p('contact')} class="hover:text-ink">{t('nav.contact')}</a></li>
      </ul>
    </div>
  </div>
  <div class="container-x py-6 border-t border-line text-xs text-mist flex justify-between">
    <span>© {year} {SITE.name}. {t('footer.rights')}</span>
    <span>Strassen · Luxembourg</span>
  </div>
</footer>
