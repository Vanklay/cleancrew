---
import { langStaticPaths } from '../../../lib/paths';
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { localizedPath, type Lang } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/ui';
export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const p = (s: string) => localizedPath(lang, s);
const posts = (await getCollection('blog', (e) => e.data.lang === lang)).sort((a, b) => +b.data.pubDate - +a.data.pubDate);
---
<Layout lang={lang} path="blog" title={`${t('blog.title')} · CleanCrew`} description={t('blog.sub')}>
  <section class="container-x pt-16 pb-24 md:pt-24 md:pb-32">
    <p class="eyebrow reveal">{t('hero.kicker')}</p>
    <h1 class="headline reveal mt-6 text-4xl md:text-6xl" style="--d:.06s">{t('blog.title')}</h1>
    <p class="reveal mt-6 mb-14 max-w-xl text-lg md:text-xl text-ink-soft" style="--d:.12s">{t('blog.sub')}</p>
    {posts.length === 0 ? <p class="text-mist">—</p> : (
      <div class="tile-grid reveal md:grid-cols-2">
        {posts.map((post) => (
          <a href={`${p('blog')}/${post.id.replace(/^[a-z]{2}-/, '')}`} class="group bg-paper p-8 transition-colors hover:bg-white md:p-10">
            <time class="text-xs font-medium uppercase tracking-wider text-mist">{post.data.pubDate.toLocaleDateString(lang)}</time>
            <h2 class="display text-xl md:text-2xl mt-3 mb-2.5">{post.data.title}</h2>
            <p class="text-ink-soft text-[15px] leading-relaxed">{post.data.description}</p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-ink transition-colors group-hover:text-accent">
              {t('blog.readmore')} <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
