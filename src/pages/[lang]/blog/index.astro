---
import { langStaticPaths } from '../../../lib/paths';
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { localizedPath, type Lang } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/ui';
export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const p = (s:string)=>localizedPath(lang,s);
const posts = (await getCollection('blog', e=>e.data.lang===lang)).sort((a,b)=>+b.data.pubDate-+a.data.pubDate);
---
<Layout lang={lang} path="blog" title={`${t('blog.title')} · CleanCrew`} description={t('blog.sub')}>
  <section class="container-x py-20 md:py-28">
    <h1 class="headline text-4xl md:text-6xl font-semibold mb-4">{t('blog.title')}</h1>
    <p class="text-lg text-ink-soft mb-14 max-w-xl">{t('blog.sub')}</p>
    {posts.length===0 ? <p class="text-mist">—</p> : (
      <div class="grid gap-px bg-line rounded-2xl overflow-hidden md:grid-cols-2">
        {posts.map(post=>(
          <a href={`${p('blog')}/${post.id.replace(/^[a-z]{2}-/,'')}`} class="bg-paper p-8 hover:bg-white transition-colors">
            <time class="text-xs text-mist">{post.data.pubDate.toLocaleDateString(lang)}</time>
            <h2 class="text-xl font-semibold mt-2 mb-2">{post.data.title}</h2>
            <p class="text-ink-soft text-[15px] leading-relaxed">{post.data.description}</p>
            <span class="mt-4 inline-block text-sm text-accent">{t('blog.readmore')} →</span>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
