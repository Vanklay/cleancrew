---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { type Lang } from '../../../i18n/config';
export async function getStaticPaths(){
  const posts = await getCollection('blog');
  return posts.map(post=>({
    params: { lang: post.data.lang, slug: post.id.replace(/^[a-z]{2}-/,'') },
    props: { post },
  }));
}
const { post } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await render(post);
---
<Layout lang={lang} path={`blog/${post.id.replace(/^[a-z]{2}-/,'')}`} type="article" title={`${post.data.title} · CleanCrew`} description={post.data.description}>
  <article class="container-x py-20 md:py-28 max-w-2xl">
    <time class="text-sm text-mist">{post.data.pubDate.toLocaleDateString(lang)}</time>
    <h1 class="headline text-3xl md:text-5xl font-semibold mt-3 mb-8">{post.data.title}</h1>
    <div class="prose-cc">
      <Content />
    </div>
  </article>
</Layout>
