---
import { langServiceStaticPaths } from '../../../lib/paths';
import Layout from '../../../layouts/Layout.astro';
import Faq from '../../../components/Faq.astro';
import BookCta from '../../../components/BookCta.astro';
import { SERVICES, SERVICE_IMAGE, localizedPath, type Lang, type Service } from '../../../i18n/config';
import { useTranslations, useRaw } from '../../../i18n/ui';

export const getStaticPaths = langServiceStaticPaths;
const lang = Astro.params.lang as Lang;
const service = Astro.params.service as Service;
const t = useTranslations(lang);
const r = useRaw(lang);
const p = (s: string) => localizedPath(lang, s);

const idx = SERVICES.indexOf(service);
const title = t(`services.${service}.title`);
const lead = t(`service.${service}.lead`);
const intro = t(`service.${service}.intro`);
const img = SERVICE_IMAGE[service];
const points = r(`service.${service}.points`) as string[];
const steps = r(`service.${service}.steps`) as string[];
const faq = [
  { q: t(`service.${service}.faq.1.q`), a: t(`service.${service}.faq.1.a`) },
  { q: t(`service.${service}.faq.2.q`), a: t(`service.${service}.faq.2.a`) },
  { q: t(`service.${service}.faq.3.q`), a: t(`service.${service}.faq.3.a`) },
];
const others = SERVICES.filter((s) => s !== service);

const serviceSchema = { name: title, serviceType: title, description: t(`services.${service}.desc`) };
const howto = { name: `${title} — ${t('service.how')}`, steps };
const metaTitle = `${title} ${t('geo.in')} · CleanCrew`;
---
<Layout
  lang={lang}
  path={`services/${service}`}
  title={metaTitle}
  description={lead}
  faq={faq}
  service={serviceSchema}
  howto={howto}
  overlayNav
>
  <!-- HERO — immersive, like the homepage: the result fills the frame -->
  <section class="hero-angle relative isolate -mt-24 overflow-hidden">
    <img src={img} alt={title} width="1290" height="720" fetchpriority="high"
         class="absolute inset-0 -z-10 h-full w-full object-cover object-center" />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink/95 via-ink/55 to-ink/20"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink/40 to-transparent"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-ink/55 to-transparent"></div>

    <div class="container-x flex min-h-[80vh] flex-col justify-end pb-24 pt-40 md:min-h-[88vh] md:pb-32">
      <div class="max-w-3xl">
        <p class="reveal flex items-center gap-3 text-xs font-bold uppercase tracking-[0.18em] text-white/70" style="--d:.04s">
          <span class="index-num text-accent">0{idx + 1}</span>
          <span class="h-px w-8 bg-white/40"></span>
          {t('hero.kicker')}
        </p>
        <h1 class="reveal mt-5 font-display font-extrabold tracking-tight leading-[1.1] text-white text-[clamp(2.5rem,6vw,5rem)]" style="--d:.08s">{title}</h1>
        <p class="reveal mt-6 max-w-xl text-base text-white/80 leading-relaxed md:text-lg" style="--d:.16s">{lead}</p>
        <div class="reveal mt-9 flex flex-wrap items-center gap-4" style="--d:.24s">
          <a href={p('book')} class="btn">{t('hero.cta')}</a>
          <a href={p('contact')} class="inline-flex items-center justify-center rounded-full border border-white/40 px-7 py-3.5 text-base font-semibold text-white transition-colors hover:bg-white hover:text-ink">{t('nav.contact')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- OVERVIEW — answer-first H2 (service + location) for SEO/AEO/GEO -->
  <section class="container-x py-28 md:py-36">
    <div class="grid gap-8 md:grid-cols-12 md:gap-16">
      <h2 class="headline reveal text-3xl md:text-5xl md:col-span-5">{title} {t('geo.in')}</h2>
      <p class="reveal text-lg md:text-xl text-ink-soft leading-relaxed md:col-span-7" style="--d:.06s">{intro}</p>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="container-x section">
    <h2 class="headline reveal text-3xl md:text-5xl mb-12 md:mb-16 max-w-xl">{t('service.included')}</h2>
    <div class="tile-grid md:grid-cols-3 reveal">
      {points.map((point, i) => (
        <div class="bg-paper p-8 md:p-10">
          <div class="index-num text-2xl text-accent mb-5">0{i + 1}</div>
          <p class="text-ink-soft leading-relaxed">{point}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- HOW IT WORKS — numbered, editorial -->
  <section class="container-x section">
    <h2 class="headline reveal text-3xl md:text-5xl mb-12 md:mb-16 max-w-xl">{t('service.how')}</h2>
    <ol>
      {steps.map((step, i) => (
        <li class="reveal grid gap-3 md:grid-cols-12 md:gap-8 border-t border-line py-8 md:py-10 md:items-baseline" style={`--d:${i * 0.06}s`}>
          <div class="md:col-span-2 index-num text-4xl md:text-6xl text-accent">0{i + 1}</div>
          <p class="md:col-span-10 text-xl md:text-2xl leading-snug max-w-3xl">{step}</p>
        </li>
      ))}
      <div class="border-t border-line"></div>
    </ol>
  </section>

  <!-- FAQ -->
  <Faq title={t('faq.title')} items={faq} />

  <!-- CROSS-SELL — the bundle, expressed as benefit -->
  <section class="container-x section">
    <h2 class="headline reveal text-3xl md:text-5xl max-w-2xl">{t('service.also')}</h2>
    <p class="reveal mt-5 mb-12 text-lg text-ink-soft max-w-xl">{t('service.alsoText')}</p>
    <div class="tile-grid md:grid-cols-2 reveal">
      {others.map((o) => (
        <a href={p(`services/${o}`)} class="group bg-paper p-8 md:p-10 transition-colors hover:bg-white">
          <h3 class="display text-2xl mb-2">{t(`services.${o}.title`)}</h3>
          <p class="text-ink-soft leading-relaxed text-[15px]">{t(`services.${o}.desc`)}</p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-ink transition-colors group-hover:text-accent">
            {t('services.learn')} <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA — with the live booking wizard -->
  <BookCta lang={lang} />
</Layout>
