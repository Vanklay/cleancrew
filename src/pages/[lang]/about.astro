---
import { langStaticPaths } from '../../lib/paths';
import Layout from '../../layouts/Layout.astro';
import Why from '../../components/Why.astro';
import Cta from '../../components/Cta.astro';
import { type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';
export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---
<Layout lang={lang} path="about" title={`${t('about.title')} ${t('geo.in')} · CleanCrew`} description={t('about.body')}>
  <section class="container-x pt-20 pb-8 md:pt-28 md:pb-12">
    <p class="eyebrow reveal">{t('hero.kicker')}</p>
    <h1 class="headline reveal mt-6 max-w-4xl text-4xl md:text-7xl" style="--d:.06s">{t('about.title')}</h1>
    <p class="reveal mt-8 max-w-3xl text-xl leading-relaxed text-ink-soft md:text-2xl" style="--d:.12s">{t('about.body')}</p>
  </section>

  <Why lang={lang} />

  <Cta lang={lang} />
</Layout>
