---
import { langStaticPaths } from '../../lib/paths';
import Layout from '../../layouts/Layout.astro';
import BookingForm from '../../components/BookingForm.astro';
import { type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';
export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---
<Layout lang={lang} path="book" title={`${t('book.title')} ${t('geo.in')} · CleanCrew`} description={t('book.sub')}>
  <section class="bg-haze pt-24 pb-24 md:pt-32 md:pb-32">
    <div class="container-x">
      <div class="mx-auto max-w-xl text-center">
        <p class="eyebrow reveal">{t('hero.kicker')}</p>
        <h1 class="headline reveal mt-6 text-4xl md:text-6xl" style="--d:.04s">{t('book.title')}</h1>
        <p class="reveal mt-5 text-lg leading-relaxed text-ink-soft" style="--d:.08s">{t('book.sub')}</p>
      </div>
      <div class="reveal mt-12 md:mt-14" style="--d:.12s"><BookingForm lang={lang} /></div>
    </div>
  </section>
</Layout>
