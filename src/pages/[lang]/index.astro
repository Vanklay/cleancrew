---
import { langStaticPaths } from '../../lib/paths';
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';
import { SERVICES, localizedPath, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';

export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const p = (s: string) => localizedPath(lang, s);

const services = SERVICES.map((key) => ({ key, href: p(`services/${key}`) }));
const why = ['1', '2', '3', '4'];

// AEO/LLM answer block — concise Q&A that LLMs and featured snippets lift
// verbatim. Rendered visibly below AND emitted as FAQPage schema. One source.
const faq = [1, 2, 3, 4, 5].map((n) => ({ q: t(`faq.${n}.q`), a: t(`faq.${n}.a`) }));

const meta = {
  fr: { title: 'CleanCrew · Débarras de garage & nettoyage au Luxembourg', desc: 'Débarras de garages, caves et greniers, nettoyage de vitres et de façades. Devis clair, équipe rapide qui revient, partout au Luxembourg.' },
  de: { title: 'CleanCrew · Garagenentrümpelung & Reinigung in Luxemburg', desc: 'Entrümpelung von Garagen, Kellern und Dachböden, Fenster- und Fassadenreinigung. Klares Angebot, schnelles Team, in ganz Luxemburg.' },
  en: { title: 'CleanCrew · Garage clearance & cleaning in Luxembourg', desc: 'Garage, cellar and attic clearance, plus window and façade cleaning. Clear quote, fast crew that comes back, anywhere in Luxembourg.' },
  lu: { title: 'CleanCrew · Garagen entrëmpelen & botzen zu Lëtzebuerg', desc: 'Entrëmpelung vu Garagen, Kelleren a Späicheren, Fënster- a Fassadebotzen. Klore Devis, séiert Team, am ganze Land.' },
  pt: { title: 'CleanCrew · Esvaziamento de garagens & limpeza no Luxemburgo', desc: 'Esvaziamento de garagens, caves e sótãos, limpeza de vidros e fachadas. Orçamento claro, equipa rápida que regressa, em todo o Luxemburgo.' },
  es: { title: 'CleanCrew · Vaciado de garajes & limpieza en Luxemburgo', desc: 'Vaciado de garajes, sótanos y desvanes, limpieza de cristales y fachadas. Presupuesto claro, equipo rápido, en todo Luxemburgo.' },
}[lang];
---
<Layout lang={lang} title={meta.title} description={meta.desc} faq={faq}>
  <!-- HERO — editorial, asymmetric, clearance is the hook into the whole property -->
  <section class="container-x pt-16 pb-20 md:pt-24 md:pb-28">
    <p class="eyebrow reveal" style="--d:.05s">{t('hero.kicker')}</p>

    <h1 class="headline reveal mt-7 text-[clamp(2.7rem,8.5vw,7.5rem)] max-w-[15ch]" style="--d:.12s">
      {t('hero.title')}<br />{t('hero.title2')}
    </h1>

    <div class="mt-10 md:mt-12 grid gap-8 md:grid-cols-12 md:items-end">
      <p class="reveal md:col-span-6 text-lg md:text-xl text-ink-soft leading-relaxed max-w-xl" style="--d:.2s">
        {t('hero.sub')}
      </p>
      <div class="reveal md:col-span-6 flex flex-wrap gap-4 md:justify-end" style="--d:.28s">
        <a href={p('book')} class="btn">{t('hero.cta')}</a>
        <a href={p('services')} class="btn-ghost">{t('hero.cta2')}</a>
      </div>
    </div>

    <div class="reveal mt-14 md:mt-20 overflow-hidden rounded-3xl" style="--d:.36s; box-shadow: var(--shadow-hero);">
      <img src="/hero.webp" alt={t('hero.title')} width="1290" height="640" fetchpriority="high"
           class="w-full h-[clamp(15rem,42vw,34rem)] object-cover" />
    </div>
  </section>

  <!-- THREE SERVICES — equal peers, numbered editorial list (no card grid) -->
  <section class="container-x section">
    <h2 class="headline reveal text-4xl md:text-6xl max-w-2xl">{t('services.title')}</h2>
    <p class="reveal mt-5 max-w-xl text-lg text-ink-soft leading-relaxed" style="--d:.06s">{t('home.services.lead')}</p>

    <div class="mt-12 md:mt-16">
      {services.map((s, i) => (
        <a href={s.href} class="group reveal block border-t border-line py-9 md:py-12 transition-colors hover:bg-white" style={`--d:${i * 0.06}s`}>
          <div class="grid gap-3 md:grid-cols-12 md:gap-8 md:items-baseline">
            <div class="md:col-span-2 index-num text-5xl md:text-7xl text-accent">0{i + 1}</div>
            <div class="md:col-span-7">
              <h3 class="display text-2xl md:text-4xl">{t(`services.${s.key}.title`)}</h3>
              <p class="mt-3 text-ink-soft leading-relaxed max-w-xl">{t(`services.${s.key}.desc`)}</p>
            </div>
            <div class="md:col-span-3 self-center md:text-right">
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-ink transition-colors group-hover:text-accent">
                {t('services.learn')} <span class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </div>
          </div>
        </a>
      ))}
      <div class="border-t border-line"></div>
    </div>
  </section>

  <!-- ONE TEAM, WHOLE PROPERTY — the positioning, the bundle as benefit -->
  <section class="container-x section">
    <div class="grid gap-10 md:grid-cols-12 md:items-start">
      <div class="md:col-span-7">
        <p class="eyebrow reveal">{t('service.also')}</p>
        <h2 class="headline reveal mt-5 text-3xl md:text-5xl" style="--d:.06s">{t('home.together.title')}</h2>
      </div>
      <div class="md:col-span-5 md:pt-2">
        <p class="reveal text-lg md:text-xl text-ink-soft leading-relaxed" style="--d:.12s">{t('home.together.text')}</p>
        <div class="reveal mt-7 flex flex-wrap gap-x-6 gap-y-2 text-sm" style="--d:.18s">
          {services.map((s) => (
            <a href={s.href} class="font-semibold text-ink transition-colors hover:text-accent">{t(`services.${s.key}.title`)}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="container-x section">
    <h2 class="headline reveal text-4xl md:text-6xl max-w-xl mb-14 md:mb-20">{t('why.title')}</h2>
    <div class="grid gap-x-10 gap-y-14 md:grid-cols-2 lg:grid-cols-4">
      {why.map((n) => (
        <div class="reveal" style={`--d:${(Number(n) - 1) * 0.06}s`}>
          <div class="index-num text-4xl md:text-5xl text-accent">0{n}</div>
          <h3 class="display text-xl mt-5 mb-2.5">{t(`why.${n}.t`)}</h3>
          <p class="text-ink-soft leading-relaxed text-[15px]">{t(`why.${n}.d`)}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ — now rendered visibly (was schema-only); the AEO answer block -->
  <Faq title={t('faq.title')} items={faq} />

  <!-- FINAL CTA — near-black band, the signature contrast moment -->
  <section class="mt-24 md:mt-32 bg-ink text-white">
    <div class="container-x py-24 md:py-36 text-center">
      <h2 class="headline reveal text-4xl md:text-7xl text-white max-w-3xl mx-auto">{t('book.title')}</h2>
      <a href={p('book')} class="btn reveal mt-12" style="--d:.08s">{t('hero.cta')}</a>
    </div>
  </section>
</Layout>
