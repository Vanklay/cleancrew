---
import { langStaticPaths } from '../../lib/paths';
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';
import BookCta from '../../components/BookCta.astro';
import QuoteEstimator from '../../components/QuoteEstimator.astro';
import Why from '../../components/Why.astro';
import { SERVICES, SERVICE_IMAGE, localizedPath, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';

export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const p = (s: string) => localizedPath(lang, s);

const services = SERVICES.map((key) => ({ key, href: p(`services/${key}`), img: SERVICE_IMAGE[key] }));

// AEO/LLM answer block — concise Q&A that LLMs and featured snippets lift
// verbatim. Rendered visibly below AND emitted as FAQPage schema. One source.
const faq = [1, 2, 3, 4, 6, 7, 8, 9, 10, 11].map((n) => ({ q: t(`faq.${n}.q`), a: t(`faq.${n}.a`) }));

const meta = {
  fr: { title: 'CleanCrew · Débarras de garage & nettoyage au Luxembourg', desc: 'Débarras de garage, nettoyage de vitres et d’allées. Devis clair, équipe rapide qui revient, partout au Luxembourg.' },
  de: { title: 'CleanCrew · Garagenentrümpelung & Reinigung in Luxemburg', desc: 'Garagenentrümpelung, Fenster- und Einfahrtreinigung. Klares Angebot, schnelles Team, in ganz Luxemburg.' },
  en: { title: 'CleanCrew · Garage clearance & cleaning in Luxembourg', desc: 'Garage clearance, plus window and driveway cleaning. Clear quote, fast crew that comes back, anywhere in Luxembourg.' },
  lu: { title: 'CleanCrew · Garagen entrëmpelen & botzen zu Lëtzebuerg', desc: 'Garagen entrëmpelen, Fënster- an Afahrtbotzen. Klore Devis, séiert Team, am ganze Land.' },
  pt: { title: 'CleanCrew · Esvaziamento de garagens & limpeza no Luxemburgo', desc: 'Esvaziamento de garagens, limpeza de vidros e acessos. Orçamento claro, equipa rápida que regressa, em todo o Luxemburgo.' },
  es: { title: 'CleanCrew · Vaciado de garajes & limpieza en Luxemburgo', desc: 'Vaciado de garajes, limpieza de cristales y accesos. Presupuesto claro, equipo rápido, en todo Luxemburgo.' },
}[lang];
---
<Layout lang={lang} title={meta.title} description={meta.desc} faq={faq} overlayNav>
  <!-- HERO — immersive: the transformed result fills the frame, headline over a gradient -->
  <section data-hero-slider class="hero-angle relative isolate -mt-24 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <img src="/hero.webp" alt={t('hero.title')} width="1290" height="640" fetchpriority="high"
           class="hero-slide absolute inset-0 h-full w-full object-cover object-center opacity-100 transition-opacity duration-[1200ms] ease-out" />
      <img src="/hero2.webp" alt="" width="1290" height="672" loading="lazy"
           class="hero-slide absolute inset-0 h-full w-full object-cover object-center opacity-0 transition-opacity duration-[1200ms] ease-out" />
      <img src="/hero3.webp" alt="" width="1290" height="672" loading="lazy"
           class="hero-slide absolute inset-0 h-full w-full object-cover object-center opacity-0 transition-opacity duration-[1200ms] ease-out" />
    </div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink/95 via-ink/55 to-ink/20"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink/40 to-transparent"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-ink/55 to-transparent"></div>

    <div class="container-x flex min-h-[94vh] flex-col justify-end pb-24 pt-40 md:min-h-[100vh] md:pb-32">
      <div class="max-w-3xl">
        <h1 class="reveal font-display font-extrabold tracking-tight leading-[1.2] text-white text-[clamp(2rem,4.4vw,4rem)]" style="--d:.08s">
          {t('hero.title')}
        </h1>
        <h2 class="reveal mt-3 font-display font-semibold tracking-tight text-white/65 text-[clamp(1.1rem,2.2vw,1.75rem)]" style="--d:.12s">{t('hero.title2')}</h2>
        <p class="reveal mt-6 max-w-xl text-base text-white/80 leading-relaxed md:text-lg" style="--d:.16s">{t('hero.sub')}</p>
        <div class="reveal mt-9 flex flex-wrap items-center gap-4" style="--d:.24s">
          <a href={p('book')} class="btn">{t('hero.cta')}</a>
          <a href={p('services')} class="inline-flex items-center justify-center rounded-full border border-white/40 px-7 py-3.5 text-base font-semibold text-white transition-colors hover:bg-white hover:text-ink">{t('hero.cta2')}</a>
        </div>
      </div>
    </div>

  </section>

  <!-- THREE SERVICES — equal peers, each shown with its result image, alternating sides -->
  <section id="services" class="container-x py-28 md:py-36 scroll-mt-28">
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
      <h2 class="headline reveal text-4xl md:text-6xl max-w-2xl">{t('services.title')}</h2>
      <p class="reveal max-w-sm text-lg text-ink-soft leading-relaxed md:text-right" style="--d:.06s">{t('home.services.lead')}</p>
    </div>

    <div class="mt-14 space-y-16 md:mt-24 md:space-y-28">
      {services.map((s, i) => (
        <a href={s.href} class="group reveal grid items-center gap-7 md:grid-cols-2 md:gap-16" style={`--d:${i * 0.05}s`}>
          <div class={`overflow-hidden rounded-[1.75rem] ${i % 2 === 1 ? 'md:order-2' : ''}`} style="box-shadow: var(--shadow-soft);">
            <img src={s.img} alt={t(`services.${s.key}.title`)} width="1290" height="672" loading="lazy"
                 class="aspect-[4/3] w-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-[1.05]" />
          </div>
          <div class={i % 2 === 1 ? 'md:order-1' : ''}>
            <div class="flex items-center gap-4">
              <span class="index-num text-xl text-accent">0{i + 1}</span>
              <span class="h-px w-12 bg-line transition-all duration-300 group-hover:w-20 group-hover:bg-accent"></span>
            </div>
            <h3 class="display mt-6 text-3xl md:text-5xl">{t(`services.${s.key}.title`)}</h3>
            <p class="mt-4 max-w-md text-lg text-ink-soft leading-relaxed">{t(`services.${s.key}.desc`)}</p>
            <span class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-ink transition-colors group-hover:text-accent">
              {t('services.learn')} <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ONE TEAM, WHOLE PROPERTY — the positioning + the SEO answer block -->
  <section class="container-x section">
    <p class="eyebrow reveal">{t('service.also')}</p>
    <h2 class="headline reveal mt-6 max-w-4xl text-4xl md:text-5xl" style="--d:.06s">{t('home.together.title')}</h2>
    <p class="reveal mt-8 max-w-3xl text-lg md:text-xl text-ink-soft leading-relaxed" style="--d:.12s">{t('home.together.text')}</p>

    <!-- one visit covers the whole exterior -->
    <div class="reveal mt-12 grid gap-px overflow-hidden rounded-2xl bg-line md:mt-16 sm:grid-cols-3" style="--d:.18s">
      {services.map((s) => (
        <a href={s.href} class="group flex items-center justify-between gap-4 bg-paper p-6 transition-colors hover:bg-white md:p-7">
          <span class="display text-base md:text-lg">{t(`services.${s.key}.title`)}</span>
          <span class="text-accent transition-transform group-hover:translate-x-1">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- APPROACH — how CleanCrew works: clear quote, one team, no subscription -->
  <section class="container-x section">
    <div class="grid gap-8 md:grid-cols-12 md:gap-16">
      <h2 class="headline reveal text-3xl md:text-5xl md:col-span-5">{t('home.approach.title')}</h2>
      <div class="md:col-span-7 space-y-5">
        <p class="reveal text-lg text-ink-soft leading-relaxed" style="--d:.06s">{t('home.approach.p1')}</p>
        <p class="reveal text-lg text-ink-soft leading-relaxed" style="--d:.1s">{t('home.approach.p2')}</p>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <Why lang={lang} />

  <!-- FAQ — now rendered visibly (was schema-only); the AEO answer block -->
  <Faq title={t('faq.title')} items={faq} />

  <!-- ESTIMATOR — instant "from" price, flows into the booking form -->
  <QuoteEstimator lang={lang} />

  <!-- BOOK — the booking wizard in a calm grey band -->
  <BookCta lang={lang} />
</Layout>

<script>
  // Hero slider — crossfade, auto-advance, pause on hover, reduced-motion aware.
  const hero = document.querySelector<HTMLElement>('[data-hero-slider]');
  if (hero) {
    const slides = Array.from(hero.querySelectorAll<HTMLElement>('.hero-slide'));
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let i = 0;
    let timer: number | undefined;
    const go = (n: number) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => (s.style.opacity = k === i ? '1' : '0'));
    };
    const start = () => { if (!reduce && slides.length > 1) timer = window.setInterval(() => go(i + 1), 5500); };
    const stop = () => { if (timer) { clearInterval(timer); timer = undefined; } };
    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', start);
    go(0); start();
  }
</script>
