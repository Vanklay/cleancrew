---
import { langStaticPaths } from '../../lib/paths';
import Layout from '../../layouts/Layout.astro';
import Cta from '../../components/Cta.astro';
import { SERVICES, localizedPath, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';
export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const p = (s: string) => localizedPath(lang, s);
---
<Layout lang={lang} path="services" title={`${t('services.title')} · CleanCrew`} description={t('hero.sub')}>
  <section class="container-x pt-20 pb-8 md:pt-28 md:pb-12">
    <p class="eyebrow reveal">{t('hero.kicker')}</p>
    <h1 class="headline reveal mt-6 max-w-3xl text-4xl md:text-7xl" style="--d:.06s">{t('services.title')}</h1>
    <p class="reveal mt-8 max-w-2xl text-lg leading-relaxed text-ink-soft md:text-2xl" style="--d:.12s">{t('home.services.lead')}</p>
  </section>

  <section class="container-x pb-28 md:pb-36">
    <div class="border-t border-line">
      {SERVICES.map((s, i) => (
        <a href={p(`services/${s}`)} class="group reveal grid items-baseline gap-4 border-b border-line py-10 transition-colors md:grid-cols-12 md:gap-8 md:py-14" style={`--d:${i * 0.05}s`}>
          <div class="index-num text-4xl text-accent md:col-span-2 md:text-5xl">0{i + 1}</div>
          <div class="md:col-span-7">
            <h2 class="display text-2xl md:text-4xl">{t(`services.${s}.title`)}</h2>
            <p class="mt-3 max-w-xl text-lg leading-relaxed text-ink-soft">{t(`services.${s}.desc`)}</p>
          </div>
          <div class="md:col-span-3 md:text-right">
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-ink transition-colors group-hover:text-accent">
              {t('services.learn')} <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Cta lang={lang} />
</Layout>
