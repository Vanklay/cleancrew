---
import { langStaticPaths } from '../../lib/paths';
import Layout from '../../layouts/Layout.astro';
import { SERVICES, localizedPath, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';
export const getStaticPaths = langStaticPaths;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const p = (s:string)=>localizedPath(lang,s);
---
<Layout lang={lang} path="services" title={`${t('services.title')} · CleanCrew`} description={t('hero.sub')}>
  <section class="container-x py-20 md:py-28">
    <h1 class="headline text-4xl md:text-6xl font-semibold mb-16 max-w-3xl">{t('services.title')}</h1>
    <div class="space-y-20">
      {SERVICES.map((s,i)=>(
        <article id={s} class="grid md:grid-cols-12 gap-8 scroll-mt-24">
          <div class="md:col-span-1 text-accent font-mono text-sm pt-2">0{i+1}</div>
          <div class="md:col-span-7">
            <h2 class="text-2xl md:text-4xl font-semibold mb-4">{t(`services.${s}.title`)}</h2>
            <p class="text-lg text-ink-soft leading-relaxed">{t(`services.${s}.desc`)}</p>
            <a href={p(`services/${s}`)} class="mt-5 inline-block text-sm text-accent hover:translate-x-1 transition-transform">{t('services.learn')} →</a>
          </div>
          <div class="md:col-span-4 md:text-right">
            <a href={p('book')} class="btn">{t('hero.cta')}</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
